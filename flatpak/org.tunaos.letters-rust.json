{
  "app-id": "org.tunaos.letters-rust",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "letters",
  "finish-args": ["--share=ipc", "--socket=fallback-x11", "--socket=wayland", "--device=dri"],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "build-args": ["--share=network"]
  },
  "modules": [{
    "name": "letters-rust",
    "buildsystem": "simple",
    "build-commands": [
      "cargo build --release -p letters",
      "install -Dm755 target/release/letters /app/bin/letters"
    ],
    "sources": [
      { "type": "dir", "path": "suite-common", "dest": "suite-common" },
      { "type": "dir", "path": "letters", "dest": "letters" },
      { "type": "file", "path": "Cargo.toml" },
      { "type": "file", "path": "Cargo.lock" }
    ]
  }]
}
