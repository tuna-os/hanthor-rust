{
  "app-id": "org.tunaos.decks-rust",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "decks",
  "finish-args": ["--share=ipc", "--socket=fallback-x11", "--socket=wayland", "--device=dri"],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "build-args": ["--share=network"]
  },
  "modules": [{
    "name": "decks-rust",
    "buildsystem": "simple",
    "build-commands": [
      "cargo build --release -p decks",
      "install -Dm755 target/release/decks /app/bin/decks"
      "install -Dm644 flatpak/org.tunaos.decks-rust.desktop /app/share/applications/org.tunaos.decks-rust.desktop",
    ],
    "sources": [
      { "type": "dir", "path": "..", "dest": "." }
    ]
  }]
}
